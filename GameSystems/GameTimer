using System;
using UnityEngine;

namespace _Scripts.GameSystems
{
    public class GameTimer
    {
        public readonly float MaxTime;
        public float CurrentTime { get; private set; }

        private bool _canCountDown;

        #region Events
        
        public event Action OnTimerStart;
        public event Action OnTimerEnd;

        #endregion
        
        public Timer(float maxTime)
        {
            MaxTime = maxTime;
        }

        public bool IsOn() => CurrentTime > 0f;

        public void Start()
        {
            CurrentTime = MaxTime;
            OnTimerStart?.Invoke();
            _canCountDown = true;
        }

        public void Tick()
        {
            if (!_canCountDown) return;
            
            CurrentTime -= Time.deltaTime;
            
            if (CurrentTime <= 0f)
                End();
        }
        
        public void End()
        {
            CurrentTime = 0;
            OnTimerEnd?.Invoke();
            _canCountDown = false;
        }
    }
}
