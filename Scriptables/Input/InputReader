using System.Collections.Generic;
using UnityEngine;
using UnityEngine.InputSystem;

namespace _Scripts.Scriptables.Input
{
    [CreateAssetMenu(fileName = "InputReader", menuName = "Scriptable Objects/InputReader")]
    public class InputReader : ScriptableObject
    {
        [SerializeField] private InputActionReference[] references;
        private Dictionary<string, object> _actions = new();

        private void OnEnable()
        {
            foreach (var reference in references)
            {
                var action = reference.action;
                action.Enable();

                action.performed += ctx => _actions[action.name] = ctx.ReadValueAsObject();
                action.canceled += ctx => _actions.Remove(action.name);
            }
        }

        private void OnDisable()
        {
            foreach (var reference in references)
                reference.action.Disable();
        }

        public T Get<T>(string actionName) => _actions.TryGetValue(actionName, out var value) ? (T)value : default;
        public bool IsHeld(string actionName) => _actions.ContainsKey(actionName);
    }

    public static class InputActions
    {
        public const string Move = "Move";
        public const string Dash = "Dash";
        public const string WallGrab = "Wall Grab";
    }
}
