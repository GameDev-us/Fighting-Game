using UnityEngine;

namespace _Scripts.Scriptables.Player
{
    [CreateAssetMenu(fileName = "MovementConfig", menuName = "Scriptable Objects/Configs/Movement Config")]
    public class MovementConfig : ScriptableObject
    {
        #region Gravity Manipulation

        [Header("Gravity Manipulation")]
        public float NormalGravityScale;
        public float FallGravityScale;

        #endregion
        
        #region Run
        
        [Header("Run")]
        public float RunSpeed;
        [Space(10)]
        
        public float RunAcceleration;
        public float RunDeceleration;
        [Space(10)]
        
        [Range(0f, 1f)] public float RunVelocityPower;
        
        [Header("Resistance")]
        [Range(0f, 1f)] public float RunFriction;
        [Space(10)]
        
        [Range(0f, 1f)] public float AirSpeedMult;
        [Range(0f, 1f)] public float AirControl;

        #endregion

        #region Jump
        
        [Header("Jump")]
        public float JumpHeight;
        [Range(0f, 1f)] public float JumpCooldown;
        [Space(10)]
        
        public float CoyoteTime;
        public float BufferTime;
        

        #endregion

        #region Climb

        [Header("Climb")]
        public float ClimbSpeed;
        [Space(10)]
        
        public float ClimbAcceleration;
        public float ClimbDeceleration;
        [Space(10)]
        
        [Range(0f, 1f)] public float ClimbVelocityPower;
        [Range(0f, 1f)] public float ClimbFriction;

        #endregion

        #region Wall Jump
        
        [Header("Wall Jump")]
        public Vector2 WallJumpForce;
        public float WallJumpCooldown;
        [Space(10)]
        
        public float WallJumpCoyoteTime;
        public float WallJumpBufferTime;
        
        #endregion

        private void OnValidate()
        {
            CoyoteTime = Mathf.Clamp(CoyoteTime, 0f, JumpCooldown);
            BufferTime = Mathf.Clamp(BufferTime, 0f, JumpCooldown);

            WallJumpCoyoteTime = Mathf.Clamp(WallJumpCoyoteTime, 0f, WallJumpCooldown);
            WallJumpBufferTime = Mathf.Clamp(WallJumpBufferTime, 0f, WallJumpCooldown);
        }
    }
}
